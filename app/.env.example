# Copy this file to .env and fill in your Supabase project keys.
# See backend/supabase/README.md for the 10-minute setup.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Must match Supabase → Authentication → URL Configuration (see SETUP.md)
EXPO_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000
# Also add to Redirect URLs: macrio://** and exp://** (password reset uses Expo Linking /auth/callback)

# Optional: Sentry crash reporting (v0.1.0). Leave empty to run without monitoring.
# Create a React Native project at https://sentry.io → copy Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=
# Public slugs for the Expo Sentry plugin (must match your Sentry org/project). Defaults: macrio / macrio
# SENTRY_ORG=macrio
# SENTRY_PROJECT=macrio
# Auth token for uploading source maps on EAS / native release builds only. Never commit.
# SENTRY_AUTH_TOKEN=
