# Copy this file to .env and fill in your Supabase project keys.
# See backend/supabase/README.md for the 10-minute setup.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Must match Supabase → Authentication → URL Configuration (see SETUP.md)
EXPO_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000
